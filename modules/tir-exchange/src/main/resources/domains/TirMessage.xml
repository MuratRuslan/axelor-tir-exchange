<?xml version="1.0" encoding="UTF-8"?>
<domain-models xmlns="http://axelor.com/xml/ns/domain-models"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://axelor.com/xml/ns/domain-models https://axelor.com/xml/ns/domain-models/domain-models_7.4.xsd">

  <module name="tir" package="kg.itg.tirexchange.db"/>

  <!--
    Replaces the hand-written @Entity kg.itg.tirexchange.data.TirMessage.
    AOP generates the JPA entity (kg.itg.tirexchange.db.TirMessage) and an
    AbstractTirMessageRepository from this definition at build time.
    Generated entities extend AuditableModel, so id/version/createdOn/updatedOn
    come for free; createdAt is kept explicit to match the original behaviour
    (processors set it and sort messages by it).
  -->
  <entity name="TirMessage" repository="abstract">
    <string name="messageType" title="Message type" index="true"/>
    <string name="guaranteeNumber" title="Guarantee number" index="true"/>
    <string name="iruReference" title="IRU reference"/>
    <string name="customsIndex" title="Customs index"/>
    <string name="status" title="Status"/>
    <string name="payload" title="Payload" large="true"/>
    <datetime name="createdAt" title="Created at"/>
  </entity>

</domain-models>
